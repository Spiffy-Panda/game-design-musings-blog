# --- Local-only / machine-specific (never committed) ---
# Identity rules, absolute paths, and tooling locations live here (see CLAUDE.md, Rule 7).
CLAUDE.local.md

# --- Scratch scripts are throwaway exploration ---
# Keep the folder's README (it documents the convention); ignore everything else.
scrap_scripts/*
!scrap_scripts/README.md

# --- Generated site output (built by utils/python/build_site.py) ---
# index.html is regenerated from MUSING-CONFIG.json; musings/ is rendered from each
# musing's MUSING.md. Sources are tracked, build output is not. See musing-tech-notes.md.
/site/index.html
/site/musings/

# --- Exploration explainer videos (built by utils/python/build_exploration_video.py) ---
# The pipeline + per-page scene scripts are tracked; rendered .mp4s and the per-scene
# build dir are large binaries, treated as build artifacts. See DEV-LOG (2026-06-27).
/explorations/_video/out/
/explorations/_video/build/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- Front-end (approaches-app: React/Tailwind via Vite) ---
# Dependencies + build output. package.json/package-lock.json + src are tracked; the
# built pages land in site/musings/ (already ignored above) via build_site.py.
approaches-app/node_modules/
approaches-app/dist/

# --- Browser-preview / Playwright MCP scratch (screenshots, console logs) ---
.playwright-mcp/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
